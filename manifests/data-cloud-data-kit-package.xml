<?xml version="1.0" encoding="UTF-8"?>
<!--
  DATA 360 / DATA CLOUD DATA KIT MANIFEST  (EXAMPLE — do not hand-build if possible)
  ============================================================================
  Preferred path:
    1. Create a DevOps Data Kit in the source sandbox.
    2. Add the Data 360 components.
    3. Click Download Manifest File.
    4. Use the downloaded package.xml for retrieve/deploy.

  If the REST manifest endpoint returns JSON dataKitMembers instead of XML,
  transform it first. Do not save that JSON response as package.xml.

  Keep Data 360 metadata in its own package/project. Starting in Winter '25,
  Salesforce doesn't allow Data 360 metadata and non-Data 360 metadata in a
  single package.

  The exact members and API version are generated by Salesforce and often
  include timestamps or long dependency names. Replace XML-safe placeholders only
  if you are intentionally repairing a generated manifest. In Markdown docs this
  value appears as <DATA_KIT_DEVELOPER_NAME>; in XML use DATA_KIT_DEVELOPER_NAME.
-->
<Package xmlns="http://soap.sforce.com/2006/04/metadata">
  <!-- Data Kit definition and generated object list -->
  <types>
    <members>DATA_KIT_DEVELOPER_NAME</members>
    <name>DataPackageKitDefinition</name>
  </types>
  <types>
    <members>DATA_KIT_OBJECT_MEMBER</members>
    <name>DataPackageKitObject</name>
  </types>

  <!-- Generated Data Kit dependencies/templates -->
  <types>
    <members>DATA_KIT_OBJECT_DEPENDENCY</members>
    <name>DataKitObjectDependency</name>
  </types>
  <types>
    <members>DATA_KIT_OBJECT_TEMPLATE</members>
    <name>DataKitObjectTemplate</name>
  </types>
  <types>
    <members>DATA_SOURCE_BUNDLE_DEFINITION</members>
    <name>DataSourceBundleDefinition</name>
  </types>
  <types>
    <members>DATA_STREAM_TEMPLATE</members>
    <name>DataStreamTemplate</name>
  </types>

  <!-- Data stream / connector metadata. Keep only types generated by your Data Kit. -->
  <types>
    <members>DATA_SOURCE_NAME</members>
    <name>DataSource</name>
  </types>
  <types>
    <members>DATA_SOURCE_OBJECT_NAME</members>
    <name>DataSourceObject</name>
  </types>
  <types>
    <members>DATA_STREAM_DEFINITION_NAME</members>
    <name>DataStreamDefinition</name>
  </types>
  <types>
    <members>DATA_CONNECTOR_NAME</members>
    <name>DataConnector</name>
  </types>

  <!-- Data model mappings and relationships. These are common failure points. -->
  <types>
    <members>DATA_SOURCE_DATA_MODEL_FIELD_MAP</members>
    <name>DataSrcDataModelFieldMap</name>
  </types>
  <types>
    <members>OBJECT_SOURCE_TARGET_MAP</members>
    <name>ObjectSourceTargetMap</name>
  </types>
  <types>
    <members>FIELD_SOURCE_TARGET_RELATIONSHIP</members>
    <name>FieldSrcTrgtRelationship</name>
  </types>

  <!-- Examples you can see when the Data Kit contains these features. -->
  <types>
    <members>CALCULATED_INSIGHT_API_NAME</members>
    <name>MktCalcInsightObjectDef</name>
  </types>
  <types>
    <members>MARKET_SEGMENT_DEFINITION</members>
    <name>MarketSegmentDefinition</name>
  </types>
  <types>
    <members>SEARCH_INDEX_CONFIGURATION</members>
    <name>DataObjectSearchIndexConf</name>
  </types>

  <version>67.0</version>
</Package>
